  "bin": {
    "faktuj-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "faktuj",
    "invoice",
    "faktura",
    "vat",
    "ai",
    "claude",
    "softvoyagers"
  ],
  "license": "MIT",
  "author": "SoftVoyagers",
  "repository": {
    "type": "git",
    "url": "https://github.com/softvoyagers/fakturka-api-mcp"
  },
  "homepage": "https://faktuj.pl",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
